# Agent Chronicle — Environment Variables
# Copy to ~/.hermes/chronicle/.env or export in your shell

# Optional: override chronicle storage directory (default: ~/.hermes/chronicle)
HERMES_CHRONICLE_DIR=~/.hermes/chronicle

# Optional: model used for diary entry generation (default: anthropic/claude-sonnet-4-6)
HERMES_CHRONICLE_MODEL=anthropic/claude-sonnet-4-6

# Optional: bearer token for the local Hermes API server at localhost:8642
# Falls back to API_SERVER_KEY if not set (Hermes default key)
HERMES_API_KEY=

# API_SERVER_KEY is used as fallback if HERMES_API_KEY is not set
# (auto-loaded from ~/.hermes/.env — no action needed if running on Hermes)
# API_SERVER_KEY=
